library(emmeans)
library(fishmethods)
library(FSA)
library(FSAdata)
library(hnp)
library(MuMIn)
library(nlraa)
library(nlstools)
library(scam)           ## version 1.2-22 or more recent
library(tidyverse)
library(visreg)

## The importation of all but one of the 21 publicly-available datasets presented in Table 1 of the main text
## can be directly achieved once the "fishmethods" and "FSAdata" packages have been activated in R. Note that
## additional steps to remove some sampled fish may be required, which is the case for the three detailed examples
## presented in the main text for (1) pinfish, (2) male black drums, and (3) female haddocks. Given that these three
## datasets are all analyzed in more details, the additional code that need to be applied are described below:

## Example 1: pinfish (Nelson 2002)

## The original pinfish dataset, which is the only one linked to the "fishmethods" package (Nelson 2025), has 670 sampled  
## males and females, and using the headtail() function of the "FSA" package will show the first and last three lines of 
## this dataset to confirm this.

headtail(pinfish)


## As indicated in Nelson (2002) and the related Fig. 4B presented in this study, both sexes were combined and with the
## analyses only conducted for pinfish exhibiting a standard length (sl) of 66 mm and greater, up to the maximum of 255 mm.
## The pinfish dataset was thus first reduced by only keeping fish within this range of lengths.

pinfish <- pinfish[which(pinfish$sl >= 66),]


## The descriptive statistics of this reduced dataset, as obtained with the Summarize() function of "FSA", now indicate that
## n = 665 pinfish exhibiting an sl varying between 66 and 255 mm are considered. Note that Nelson (2002) reports using n = 658
## pinfish in his original analyses, such that apparently seven additional individual fish were considered here.

Summarize(sl ~ 1, data = pinfish)


## Example 2: male black drums [bdm] (Ogle 2016)

## This example is originally used in the excellent fisheries-related textbook of Ogle (2016, Chapter 12) to show the detailed
## application of the von Bertalanffy growth model (VBGM) in which only the males from the BlackDrum2001 dataset found in "FSAdata"
## are used. As a first step, only the males are kept and, as done by Ogle (2016), a 51-year-old (oldest) male is also removed,
## leaving a total of 74 males aged between 3 and 42 years old. To be consistent with Ogle (2016), the reduced dataset is referred to
## as *bdm* for black drum males.

bdm <- BlackDrum2001 [which(BlackDrum2001$sex == "male"),]
bdm <- bdm[which(bdm$otoage < 51),]
Summarize(otoage ~ 1, data = bdm)


## Example 3: female haddocks (Honsey et al. 2017)

## This is the only dataset hosted on Dryad: https://datadryad.org/dataset/doi:10.5061/dryad.vb957 but to facilitate its importation
## into R, the same dataset has been made available here in a .txt format in which *Season = SPRING*, *Year = 2015*, and *Sex = 2* 
## (i.e., female), correspond to information that is common to all sampled female haddocks, such that it was removed. This modified
## dataset is found on this same repository and can be automatically imported into R from using the following url link together with 
## the read.delim() function.

url <- "https://raw.githubusercontent.com/julienmainguy/Modeling-fish-growth/refs/heads/main/haddock.txt"
haddock <- read.delim(url)

## If the automatic importation of the *haddock* dataset fails, it can be downloaded from this same repository and loaded into R with
## with the read.delim() function.

## This dataset was however further reduced by Honsey et al. (2017) by discarding the two smallest females despite the fact that these
## two observations did not appear to represent outliers, but could possibly have had a leverage effect on the linear relationship describing
## the first phase of the biphasic growth model and could thus possibly having been removed for such reason. Regardless of the reason 
## behind their removal, the original dataset was reduced to n = 359 by only containing female haddocks exhibiting a total lenght (tl) 
## of 20 cm or more.

haddock <- haddock[which(haddock$TotalLength >= 20),]
Summarize(Age ~ 1, data = haddock)


## In the other 18 examples, the removal of NA's sometimes needed to be performed prior to analyze the length-at-age data, such as in the
## RuffeSLRH92 data with n = 738 sampled fish of which only 12 had their age identified, as indicated from using the Summarize() function
## of "FSA" under *nvalid*, such that all the sampled fish with NA's for the *age* variable were removed.

Summarize(age ~ 1, data = RuffeSLRH92)

RuffeSLRH92 <- RuffeSLRH92[!is.na(RuffeSLRH92$age),]
Summarize(age ~ 1, data = RuffeSLRH92)


## NOTE

## As the overall analytical approach is identical for all datasets, only the analysis of the second example for the 74 male black drums (Ogle 2016)
## is shown below given that it is associated with a small sample size and thus, requires less computational time for demonstrative purposes.


######################### COMMONLY-USED GROWTH MODELS (VON BERTALANFFY, GOMPERTZ, LOGISTIC, AND RICHARDS) #########################################

## Application of the VBGM, with the Gompertz and logistic growth models following the same approach. First, the von Bertalanffy growth
## function, i.e. VB_fun(), is defined using "FSA".

VB_fun <- makeGrowthFun(type = "von Bertalanffy")
## GZ_fun <- makeGrowthFun(type = "Gompertz")       ## shown but not used below
## LG_fun <- makeGrowthFun(type = "logistic")       ## shown but not used below
RG_fun <- makeGrowthFun(type = "Richard")


## Starting values for the VBGM and RGM are first estimated and stored in the objects *sv_bdm_VB* and *sv_bdm_RG*, respectively, with the same step 
## identically achieved for the GGM and LGM (not shown) to compare all common growth models, again using "FSA". Note that fish length is *tl* for 
## total length in the *bdm* dataset, where and age corresponds to *otoage*, such that these two variables will be modeled as such below.

sv_bdm_VB <- findGrowthStarts(tl ~ otoage, 
                                   type = "von Bertalanffy",
                                   plot = TRUE,
                                   data = bdm)

sv_bdm_RG <- findGrowthStarts(tl ~ otoage, 
                                   type = "Richards",
                                   plot = TRUE,
                                   data = bdm)


## Obtain the final VBGM and RGM from jointly using the the VB_fun() and RG_fun() functions with corresponding estimated starting values

m_bdm_VB <- nls(tl ~ VB_fun(otoage, Linf, K, t0),
                start = sv_bdm_VB, 
                data = bdm)

m_bdm_RG <- nls(tl ~ RG_fun(otoage, Linf, k, ti, b),    ## note the there are 4 growth parameters that differ from the three of the VBGM
                start = sv_bdm_RG, 
                data = bdm)


## Yield the summary output and ask for the estimation of the correlation coefficients between the three growth parameters, as provided by the
## "nlstools" package.

summary(m_bdm_VB, correlation = TRUE)

summary(m_bdm_RG, correlation = TRUE)


## MODEL ADEQUACY

## Check the adequacy of *m_bdm_VB* with newly-available helper functions for the "hnp" package. A general Growth Function (GF) must first be created
## and is identically used for the VBGM, GGM, LGM, and RGM. But first, the (i) model, (ii) specific growth function, and (iii) dataset are defined for 
## their use with the associated code. Note that all the code rely on the information provided for (i), (ii), and (iii).

model <- m_bdm_VB          ## change for *m_bdm_RG* to test the RGM
growth_fun <- VB_fun       ## change for *RG_fun* to test RGM 
dataset <- bdm

GF <- function(formula, start, data) {
               y <- data[[paste(formula[[2]])]]
                        fit <- nls(formula = formula,
                                   start = start,
                                   data = data)
            res <- y - as.numeric(fitted(fit))
      return(list(fit = fit, residuals = res))
}


## The growth models being assessed for its adequacy, here *m_bdm_VB* and *m_bdm_RG*, are refitted as the *original_model* with the just-created
## GF() function and the specific one for the investigated growth model, here VB_fun() and RG_fun(), which have already been previously defined. 
## Note that how the variables *LENGTH* and *AGE* are referred in the dataset must be indicated in an identical manner in the code, here with
## *tl* and *otoage*, respectively.

original_model <- GF(tl ~ VB_fun(otoage, Linf, K, t0),       ## use *GF(tl ~ RG_fun(otoage, Linf, k, ti, b)* for the RGM
                     start = sv_bdm_VB,                      ## use *start = sv_bdm_RG* for the RGM
                     data = dataset)


## Then, the helper functions dfun(), sfun(), and ffun() are defined to be used with the hnp() function of "hnp". The dfun() and sfun()
## functions remain the same at all times, whereas the ffun() function must list the three specific growth parameters being used. 

dfun <- function(obj) obj$residuals

sfun <- function(n, obj) {
  theta <- coef(obj$fit)
  mu <- VB_fun(bdm$otoage, theta[1], theta[2], theta[3])   ## *AGE* variable here = *otoage* and add *,theta[4]* for the RGM
  sigma <- sigma(obj$fit)
  y <- rnorm(length(mu), mu, sigma)
  try_fit <- try(ffun(y), silent = TRUE)
  while(inherits(try_fit, "try-error")) {
    y <- rnorm(length(mu), mu, sigma)
    try_fit <- try(ffun(y), silent = TRUE)
  }
  return(y)
}

ffun <- function(newresp) {
  fit <- GF(newresp ~ growth_fun(otoage, Linf, K, t0),    ## *AGE* variable here = *otoage* and use *growth_fun(otoage, Linf, k, ti, b),* for the RGM
            start = sv_bdm_VB,                            ## use *start = sv_bdm_RG* for the RGM
            data = dataset %>% mutate(newresp = newresp))
  return(fit)
}


## Adequacy assessment based on a single diagnostic iteration with "hnp". A half-normal plot with a simulated envelope is produced.
## Because of the simulations being used, each requested iteration will produce results that slightly vary. The paint = TRUE argument
## is used such that the residuals found outside the envelope are shown in red, whereas the print = TRUE argument displays the number 
## and percentage of residuals found outside the envelope directly on the half-normal plot. It is recommended to first perform a single 
## hnp diagnostic to visually assess how the residuals are distributed relative to the simulated envelope. For instance, a percentage of
## residuals found outside the envelope near 0% or 1% already indicates that the considered model is sufficiently adequate, whereas a 
## high value such as 47% or 89% is instead clearly indicative of an inadequate model.

hnp(original_model,
    newclass = TRUE,
    diagfun = dfun,
    simfun = sfun,
    fitfun = ffun,
    how.many.out = TRUE,
    paint = TRUE,
    print = TRUE)


## Ideally, an adequacy assessment with "hnp" should be based on more diagnostic iterations, such as n = 10, to account for the fact
## that the envelope limits are simulated. This is especially true when a single "hnp" provides a percentage that is close the proposed
## arbitrary threshold of 10%. On the other hand, using more iterations translates in more computational time being required to perform
## such adequacy assessment, as done below. Note that he seed *2026* is solely used for reproducibility. This assessment takes several minutes
## to be fully performed. The dfun, sfun, and ffun functions are the same as the ones defined in the previous steps above for the VBGM being
## considered.

set.seed(2026)
n <- 10
hnp_obj <- list()
for(i in 1:n) {
  hnp_obj[[i]] <- hnp(original_model,
                   newclass = TRUE,
                   diagfun = dfun,
                   simfun = sfun,
                   fitfun = ffun,
                   how.many.out = TRUE,
                   plot.sim = FALSE)
}


## The results of all the diagnostic iterations are then saved in the *hnp_summary* object.

hnp_summary <- sapply(hnp_obj, function(x) x$out / x$total * 100) 


## Estimate the modal percentage of residuals found outside the simulated envelope (see Mainguy et al. 2026) using the *hnp_summary* object.

return_max <- function(numvec) {
  dens <- density(numvec)
  return(dens$x[which.max(dens$y)][1])
}
round(return_max(hnp_summary), 2)


## MODEL IN-SAMPLE PREDICTIVE PERFORMANCE

## Estimate the (unadjusted) coefficient of determination (R2) with the R2M() function of the "nlraa" package.

R2M(m_bdm_VB)$R2 * 100

R2M(m_bdm_RG)$R2 * 100


## ADJUSTED ROOT MEAN SQUARE ERROR (RMSE_adj), here for *m_bdm_VB* as an example

model <- m_bdm_VB    ## change for *m_bdm_RG* to calculate the RMSE_adj of the RGM

n <- length(bdm$otoage)
logLik <- logLik(model)
P <- attributes(logLik)$df
prediction <- predict(model, bdm, type = "response")
RSS <- sum((prediction - bdm$tl)^2)
(RMSE_adj <- sqrt(RSS / (n - P)))


## LEAVE-ONE-OUT CROSS-VALIDATION (LOO-CV) WITH ONE-STANDARD-ERROR (1SE) RULE BASED ON THE MEAN UNADJUSTED RMSE

## In this example, removing one observation at a time did not create modeling issues, but this can occur and
## would result in having one or likely more zeros values in the data frame containing all the computed RMSE values.
## If such situation occurs, the Summarize() function of "FSA" will generate an additional metric *percZero* to
## indicate the percentage of zeros in the considered dataset. As no observed value is expected to directly correspond
## to the predicted value, a zero is highly likely to be attributable to a convergence issue or else. As a result,
## the LOO-CV process will be unreliable as the mean RMSE will be further reduced (i.e., lower mean RMSE = better) by
## the presence of these zeros. Removing these zeros will not allow to compare the mean RMSE on a same basis neither 
## when it is compared to another candidate model that experienced no analytical issues. As such, models compared based
## on the LOO-CV approach with 1SE rule must have an RMSE value associated to each iterative step. Below only the VBGM
## is tested, but the function can be adapted for the GGM, LGM, and RGM.

n <- length(bdm$otoage)                                                                             ## as already defined in the previous step above
RMSE <- numeric(n)

for (i in 1:n) {
  train <- bdm[-i, ]                                                                                ## leave out the i-th observation to create a new *train* dataset each time
  test <- bdm[i, ]                                                                                  ## keep the i-th observation as the *test* dataset (n = 1) each time 
  sv_bdm_VB <- findGrowthStarts(tl ~ otoage, type = "von Bertalanffy", plot = TRUE, data = train)   ## estimate the starting values based on the *train* dataset (adjust for other growth models)
  model <- nls(tl ~ VB_fun(otoage, Linf, K, t0), start = sv_bdm_VB, data = train)                   ## estimate the three growth parameters for the final VBGM based on the "train" dataset (adjust for other growht models)
  prediction <- predict(model, test, type = "response")                                             ## yield the related predicted value for the single observation contained in the "test" dataset
  RMSE[i] <- sqrt(mean((prediction-test$tl)^2))                                                     ## calculate the RMSE each time
}

## Store all the RMSE values in a same data frame, here again with VBGM as an example

results_bdm_VB <- data.frame(METHOD = "VB", RMSE)                                                


## Obtain the mean RMSE from this LOO-CV approach for the VBGM

(mean(results_bdm_VB$RMSE))


## Calculate the estimated standard error (SE) for the same VBGM to be used for the 1SE rule

(sd(results_bdm_VB$RMSE)/sqrt(n))       


## Obtain the parameter degrees of freedom (d.f.) referred to as *P* in the main text, which is always P = 4 for the VBGM, GGM, and LGM,
## and P = 5 for the RGM

logLik <- logLik(m_bdm_VB)
(attributes(logLik)$df)                           


## Comparison relying on an information-theoretic approach based on the Bayesian Information Criterion (BIC)

## BIC(m_bdm_VB, m_bdm_GZ, m_bdm_LG, m_bdm_RG)                                                   ## once the GGM and LGM have also been fitted


## PREDICTED VALUES

model <- m_bdm_VB 
nd <- data.frame(otoage = seq(min(bdm$otoage), max(bdm$otoage), by = 0.1))                       ## select an incremental value (i.e., by = 0.1) allowing to offer a smoothed curve
estimate <- predict(model, nd, type = "response")
results <- data.frame(nd, estimate)
plot(tl ~ otoage, data = bdm)                                                                    ## quick simple plot showing the observed values
points(estimate ~ otoage, data = results, pch = 20, type = "b", lwd = 1.5, col = "red")          ## adding the predicted values to assess their fit to the length-at-age data


############################## SHAPE-CONSTRAINED ADDITIVE MODELING (SCAM) FRAMEWORK #############################################

## The smooth function s() applied to *otoage* below will impose through *s(otoage, bs = "micv")* a monotically (m) increasing (i) and convave (cv) 
## curvilinear pattern using the "scam" package.

## Gaussian distribution with identity link while also using the efs optimizer

m_bdm_SCAM_GAUSSIAN <- scam(tl ~ s(otoage, bs = "micv"),    
                            family = gaussian,
                            optimizer = "efs",
                            data = bdm)

summary(m_bdm_SCAM_GAUSSIAN)


## Use the gamma distribution with log link as an alternative (again with the efs optimizer)

m_bdm_SCAM_GAMMA <- scam(tl ~ s(otoage, bs = "micv"),
                        family = Gamma(link = "log"),
                        optimizer = "efs",
                        data = bdm)

summary(m_bdm_SCAM_GAMMA)


## MODEL ADEQUACY

## Check the adequacy of both models from using slightly modified helper functions for "hnp" presented in Mainguy et al. (2026) for GAMs fitted with "mgcv".
## Given that the "scam" package is a direct extension of "mgcv", the required helper functions are nearly identical. In all cases, the sfun() helper function
## must be correctly specified relative to the distribution family used, i.e. Gaussian or gamma with log link in this study (see Mainguy et al. 2026). First, 
## the (i) model, (ii) distribution family, (iii) optimizer, and (iv) dataset used are specified to then proceed with the step of adequacy assessment. The ffun()
## helper function always need to have the right-part next to *resp ~* be identical to the model being tested (e.g., if *age* is written as *Age* for instance).

## Assessment of the Gaussian SCAM requiring that the normality and homoscedasticity assumptions are sufficiently respected.

## First perform a single "hnp" diagnostic to produce a half-normal plot with a simulated envelope

model <- m_bdm_SCAM_GAUSSIAN 
family <- gaussian
optimizer <- "efs"
dataset <- bdm

dfun <- function(obj) resid(obj, type = "deviance")

sfun <- function(n, obj) {
            y <- rnorm(nrow(dataset),
                       mean = predict(model, type = "response"),
                       sd = sqrt(model$sig2))
            return(y)
}

ffun <- function(resp) {
             scam(resp ~ s(otoage, bs = "micv"),                            # the *AGE* variable must be correcly typed, here = *otoage*
                  family = family,
                  optimizer = optimizer,
                  data = dataset)
}

hnp(model, 
    newclass = TRUE,
    diagfun = dfun,
    simfun = sfun,
    fitfun = ffun,
    how.many.out = TRUE,
    paint = TRUE,
    print = TRUE)


## Perform 10 "hnp" iterations to get a modal percentage of residuals found outside the simulated envelope. This takes a few minutes to run.

set.seed(2026)
n <- 10
hnp_obj <- list()
for (i in 1:n) {
  hnp_obj[[i]] <- hnp(model, 
                      newclass = TRUE,
                      diagfun = dfun,
                      simfun = sfun,
                      fitfun = ffun,
                      how.many.out = TRUE,
                      plot.sim = FALSE)
}

hnp_summary <- sapply(hnp_obj, function(x) x$out / x$total * 100) 

return_max <- function(numvec) {
  dens <- density(numvec)
  return(dens$x[which.max(dens$y)][1])
}
round(return_max(hnp_summary), 2)


## Assessment of the gamma SCAM requiring that the variance is sufficiently proportional to the mean. Note that the sfun() function for the
## gamma SCAM differs from that of the Gaussian SCAM given that it is distribution-specific.

## First perform a single "hnp" diagnostic

model <- m_bdm_SCAM_GAMMA
family <- Gamma(link = "log")
optimizer <- "efs"
dataset <- bdm

dfun <- function(obj) resid(obj, type = "deviance")

sfun <- function(n, obj) {
  mu_hat <- fitted(obj)
  phi <- summary(obj)$dispersion
  shape <- 1 / phi
  scale <- mu_hat * phi
  y <- rgamma(n = length(mu_hat), shape = shape, scale = scale)
  return(y)
}

ffun <- function(resp) {
        scam(resp ~ s(otoage, bs = "micv"),                            # the *AGE* variable must be correcly typed, here = *otoage*
             family = family,
             optimizer = optimizer,
             data = dataset)
}

hnp(model, 
    newclass = TRUE,
    diagfun = dfun,
    simfun = sfun,
    fitfun = ffun,
    how.many.out = TRUE,
    paint = TRUE,
    print = TRUE)


## Perform 10 "hnp" iterations to get a modal percentage of residuals found outside the simulated envelope. This takes a few minutes.

set.seed(2026)
n <- 10
hnp_obj <- list()
for(i in 1:n) {
  hnp_obj[[i]] <- hnp(model,
                   newclass = TRUE,
                   diagfun = dfun,
                   simfun = sfun,
                   fitfun = ffun,
                   how.many.out = TRUE,
                   plot.sim = FALSE)
}

hnp_summary <- sapply(hnp_obj, function(x) x$out / x$total * 100) 

return_max <- function(numvec) {
  dens <- density(numvec)
  return(dens$x[which.max(dens$y)][1])
}
round(return_max(hnp_summary), 2)


## MODEL IN-SAMPLE PREDICTIVE PERFORMANCE

## The (unadjusted) coefficient of determination (R2) for a Gaussian SCAM or the (unadjusted) deviance explained (D2) for a gamma SCAM
## are directly provided in the scam() function output under "Deviance explained" (see main text). Briefly, D2 is the R2 analogue for
## non-Gaussian models, such as for the gamma SCAM, and is estimated as follows:

model <- m_bdm_SCAM_GAMMA
(D2 <- 100 * (1 - model$deviance / model$null.deviance))          # should match the value provided under "Deviance explained" in the model output


## Note that the adjusted R2 provided in the scam() function output (i.e.,*R-sq.(adj)*) is only valid for the Gaussiance case. If one needs to 
## penalize (i.e. adjust) D2 for model complexity to yield an adjusted D2 (D2_adj), the proposed adjustement by Guisan and Zimmermann (2000) should
## be used, as presented in Mainguy et al. (2026) for GAMs, such that D2_adj < D2 in all instances.

model <- m_bdm_SCAM_GAMMA
D2 <- 100 * (1 - model$deviance / model$null.deviance)
logLik <- logLik(model)
P <- attributes(logLik)$df
n <- summary(model)$n
(D2_adj <- 100 - ((n - 1) / (n - P) * (100 - D2)))


## RMSE_adj, LOO-CV with 1SE rule, and BIC

## The three different approaches used to compare the penalized goodness-of-fit of the up to five candidate growth models
## are completely identical to those described above for the VBGM. Below, only the Gaussian SCAM is considered to yield
## these values as an example for the RMSE_adj and LOO-CV with 1SE rule.

## IMPORTANT: 

## As opposed to the VBGM, GGM, and LGM, each SCAM will vary in its model parameter d.f. (P) depending on how many
## effective degrees of freedom (edf) it requires to generate the smoothed growth curve (i.e. less nonlinearity, less edf).
## The penalization of the model relies on the "equivalent-df" of the model incorporating both the df (i.e., intercept) and edf.
## As such, P for the RMSE_adj and the last part of the code for the LOO-CV and 1SE rule will provide the value reflecting the
## complexity of the considered SCAM, which is often > 4 (i.e. the fixed value of the VBGM) but can also sometimes be < 4.

## RMSE_adj (Gaussian SCAM)

n <- length(bdm$otoage)
logLik <- logLik(m_bdm_SCAM_GAUSSIAN)
P <- attributes(logLik)$df
prediction <- predict(m_bdm_SCAM_GAUSSIAN, bdm, type = "response")
RSS <- sum((prediction - bdm$tl)^2)
(RMSE_adj <- sqrt(RSS / (n - P)))


## LOO-CV and 1SE rule (Gaussian SCAM)

n <- length(bdm$otoage)
RMSE <- numeric(n)

for (i in 1:n) {
  train <- bdm[-i, ]
  test <- bdm[i, ]
  model <- scam(
  tl ~ s(otoage, bs = "micv"), family = gaussian, optimizer = "efs", data = train)
  prediction <- predict(model, test, type = "response")
  RMSE[i] <- sqrt(mean((prediction-test$tl)^2))
}

results_bdm_SCAM_GAUSSIAN <- data.frame(METHOD = "SCAM_GAUSSIAN", RMSE)
Summarize(RMSE ~ 1, data = results_bdm_SCAM_GAUSSIAN)

(sd(results_bdm_SCAM_GAUSSIAN$RMSE)/sqrt(n))

logLik <- logLik(m_bdm_SCAM_GAUSSIAN)
(attributes(logLik)$df)


## Comparison relying on an information-theoretic approach based on BIC

## Note that the inadequate gamma SCAM is much better supported than the adequate Gaussian SCAM when relying on BIC.
## Any information criteria, like AIC and BIC, will rank model regardless of whether they respect their distributional
## assumptions or not. In this case, the gamma SCAM was previously identified as being inadequate and therefore, should
## not be considered for model selection purposes, but is compared here to the Gaussian SCAM to illustrate this point.

BIC(m_bdm_SCAM_GAUSSIAN, m_bdm_SCAM_GAMMA)


## PREDICTED VALUES

## The predicted values of both models can be yielded in the exact same manner as presented for the VBGM above. However,
## this can be more rapidely achieved from making use of the visreg() function of the "visreg" package and asking to
## generate the predicted values and related uncertainty at the response scale. Below the code for the Gaussian SCAM to 
## which we also add the observed values with the points() function.

visreg(m_bdm_SCAM_GAUSSIAN, scale = "response", rug = FALSE, ylim = c(min(bdm$tl), max(bdm$tl)))
points(tl ~ otoage, pch = 20, data = bdm)


############## MULTIPLE-COMPARISON TEST WHEN THREE GROUPS (LEVELS) OR MORE ARE CONSIDERED FOR A CATEGORICAL VARIABLE (PREDICTOR) #####################

## Automatically load the size-at-age data from female lake trout sampled in three nearby water bodies (TROUT dataset; Mainguy et al., 2026)

url <- "https://raw.githubusercontent.com/julienmainguy/GAM-adequacy/refs/heads/main/TROUT"
TROUT <- read.delim(url)

## If the automatic importation of the *TROUT* dataset fails, it can be downloaded from the *GAM-adequacy* repository found on the same GitHub and loaded
## into R with the read.delim() function. Otherwise, the *TROUT* dataset is directly found here: https://github.com/julienmainguy/GAM-adequacy


## Fit a model in which Total Length (TL) is a function of LAKE included as a fixed (categorical) effect and AGE included as a mixed-constraints smooth term.

TROUT$LAKE <- as.factor(TROUT$LAKE)                      ## categorical fixed or random effects need to first be defined as a factor

m_TROUT_LAKE <- scam(TL ~ LAKE + s(AGE, bs = "micv"),
                    family = Gamma(link = "log"),
                    optimizer = "efs",
                    data = TROUT)

summary(m_TROUT_LAKE)


## Fit an alternative (*_ALT*) model for which the fixed LAKE effect is excluded for comparative purposes (i.e., evaluate its importance)

m_TROUT_ALT <- scam(TL ~ 1 + s(AGE, bs = "micv"),
                    family = Gamma(link = "log"),
                    optimizer = "efs",
                    data = TROUT)

summary(m_TROUT_ALT)


## Although not shown here, the step of adequacy assessment with the helper functions for "hnp" would indicate that both gamma SCAMs are inadequate.
## However, pretending that these would be sufficiently adequate for demonstration purposes, the "MuMIn" package is first used to compare these two
## candidate models under an information-theoretic approach based on the BIC.

model.sel(m_TROUT_ALT, m_TROUT_LAKE, rank = BIC)


## Next, perform a multiple-comparison test with adjusted p-values according to Tukey's method for the 3 possible pairwise comparisons using "emmeans".
## Note that using the pairs() function will provide estimates at the linear predictor scale only for models fitted with "scam", such that in
## this case, although not indicated in the results output, the parameter estimates are those yielded on the log scale for this gamma SCAM.

emm_TROUT_LAKE <- emmeans(m_TROUT_LAKE, "LAKE")
pairs(emm_TROUT_LAKE)

## Statistical support is found to indicate that female lake trout from LAKE *A* exhibit a lower growth than those of LAKE *B* and *C*, the latters
## having instead similar growth curves from a statistical standpoint. 


## The plot() function of "emmeans" then allows to visualize the differences between the three LAKE-specific parameter estimates with their respective
## 95% confidence intervals, again at the linear predictor (log) scale.

plot(emm_TROUT_LAKE)


## The differences between the LAKE-specific estimates can alternatively be visualized at the response scale with "visreg" by keeping AGE constant
## from centering it on its median (default setting).

visreg(m_TROUT_LAKE, scale = "response", "LAKE")
